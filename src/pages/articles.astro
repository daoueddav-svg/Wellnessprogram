---
import MainLayout from '../layouts/MainLayout.astro';

const title = "Clinical Insights & Articles | Wellness Sanctuary";
const description = "Explore our latest data-driven articles, clinical comparisons, and independent reviews of top wellness programs and nootropics.";

const articles = [
  {
    title: "AG1 versus FS Greens: Which Superfood Powder is Right for You in 2026",
    url: "/blog/ag1-vs-fs-greens",
    category: "Nutrition",
    date: "May 2026",
    image: "https://images.unsplash.com/photo-1515543904379-3d7570072921?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Mind Lab Pro versus Hunter Focus: The Ultimate Brain Booster Showdown 2026",
    url: "/blog/mind-lab-pro-vs-hunter-focus",
    category: "Mental Performance",
    date: "May 2026",
    image: "https://images.unsplash.com/photo-1559757175-5700dde675bc?q=80&w=800&auto=format&fit=crop"
  }
];
---

<MainLayout title={title} description={description}>
  <main class="max-w-4xl mx-auto px-6 py-20 min-h-screen">
    <header class="mb-16">
      <h1 class="text-5xl md:text-6xl text-slate-900 leading-tight mb-6" style="font-family:'Noto Serif',serif;">
        Clinical Insights & Articles
      </h1>
      <p class="text-lg text-slate-700">Data-driven analysis and independent reviews to guide your wellness journey.</p>
    </header>

    <div class="space-y-6">
      {articles.map((article) => (
        <a href={article.url} class="group block bg-white border border-slate-200 rounded-xl p-4 hover:shadow-lg transition-all hover:border-emerald-600">
          <div class="flex flex-col md:flex-row md:items-center gap-6">
            <!-- Thumbnail -->
            <div class="w-full md:w-56 h-40 md:h-32 flex-shrink-0 overflow-hidden rounded-lg">
              <img src={article.image} alt={article.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            
            <!-- Content -->
            <div class="flex-grow">
              <span class="text-[10px] uppercase tracking-widest text-slate-500 font-bold mb-2 block">{article.category}</span>
              <h2 class="text-xl md:text-2xl text-slate-900 group-hover:text-emerald-600 transition-colors" style="font-family:'Noto Serif',serif;">
                {article.title}
              </h2>
            </div>
            
            <!-- Action / Date -->
            <div class="flex items-center justify-between md:flex-col md:items-end md:justify-center gap-2 md:gap-4 text-slate-500 flex-shrink-0 md:ml-4">
              <span class="text-xs font-semibold whitespace-nowrap">{article.date}</span>
              <span class="text-emerald-600 bg-emerald-50 w-8 h-8 rounded-full flex items-center justify-center group-hover:bg-emerald-600 group-hover:text-white transition-colors">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>
</MainLayout>
