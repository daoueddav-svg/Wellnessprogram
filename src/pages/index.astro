---
import MainLayout from '../layouts/MainLayout.astro';
import { featuredProducts, expert } from '../data/products';
---
<MainLayout title="Wellness Sanctuary | Best Wellness Programs Reviewed 2024" description="Independent expert comparisons of the best wellness programs: Noom, Ritual, Alo Moves, WHOOP.">
<main>
  <!-- Hero -->
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden px-8">
    <div class="absolute inset-0 z-0">
      <img class="w-full h-full object-cover opacity-15 mix-blend-multiply" alt="Serene spa interior" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDEBn1dZoCKgtCp6Y0ykeKJfIkfqEQ6zvwg1Refve6oZbs3JAcJ4UWyYEiTeBIs139TeRz0P-y6Evi8dbNvVVhex3uBbop8TpFtPyfeexx5HmQRfkowMrVaYVpGpk5cPkkECl95N-qo2xhT83fJ5gk7iIhEysCE-0AoL2G3wjyBJ5CBT90CXkOe6Gft5xVPZ_3jX0n5U4byqmTD9NgY8azH6JzTq7Y5p8IsigoTw5dkil6sQczSJrwBXb0rNw9KAJyxzpL99uDZUyQ"/>
      <div class="absolute inset-0 bg-gradient-to-b from-[#f9f9f7]/0 via-[#f9f9f7]/40 to-[#f9f9f7]"></div>
    </div>
    <div class="relative z-10 max-w-4xl text-center">
      <span class="inline-block text-xs uppercase tracking-[0.2em] text-slate-900 mb-6 font-semibold">Medically Reviewed · 2024</span>
      <h1 class="text-5xl md:text-7xl text-slate-900 leading-[1.1] mb-8" style="font-family:'Noto Serif',serif;">Your wellness journey,<br/><em>optimised by science</em></h1>
      <p class="text-lg md:text-xl text-slate-700 max-w-2xl mx-auto mb-10 leading-relaxed">Independent expert comparisons, honest medical reviews, and personalised recommendations to help you choose the wellness program that truly fits you.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="/quiz"><button class="bg-emerald-600 text-white px-10 py-4 rounded-xl text-lg font-medium hover:shadow-xl transition-all active:scale-95">Find My Program →</button></a>
        <a href="/comparison" class="flex items-center gap-2 text-slate-900 font-semibold py-4 group">
          <span>See the full comparison</span>
          <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
      </div>
      <div class="mt-12 flex flex-wrap items-center justify-center gap-8 text-sm text-slate-500">
        <span>✓ <strong class="text-slate-900">8 programs</strong> analysed</span>
        <span>✓ <strong class="text-slate-900">12 years</strong> of medical expertise</span>
        <span>✓ <strong class="text-slate-900">100% independent</strong> reviews</span>
      </div>
    </div>
  </section>

  <!-- Bento Grid -->
  <section class="max-w-screen-2xl mx-auto px-8 py-24">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
      <div class="max-w-2xl">
        <h2 class="text-4xl md:text-5xl text-slate-900 mb-6" style="font-family:'Noto Serif',serif;">Expert-Selected Programs</h2>
        <p class="text-slate-700 text-lg">Each program is scored across 12 medical criteria. Only those achieving the highest scores earn our validation badge.</p>
      </div>
      <a href="/comparison"><div class="px-5 py-2.5 rounded-full border border-slate-300 text-sm uppercase tracking-widest text-slate-500 hover:border-emerald-600 hover:text-slate-900 transition-colors whitespace-nowrap cursor-pointer">View full comparison</div></a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
      {featuredProducts[0] && (
        <a href={featuredProducts[0].affiliateUrl} target="_blank" rel="noopener sponsored" class="md:col-span-8 group relative overflow-hidden rounded-xl bg-white shadow-sm hover:shadow-xl transition-all min-h-[380px] flex flex-col border border-slate-200 p-10">
          {featuredProducts[0].badge && <div class="absolute top-6 left-6 z-20 bg-emerald-600 text-white px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider shadow-sm">★ {featuredProducts[0].badge}</div>}
          <div class="absolute top-6 right-6 z-20 bg-slate-50 border border-slate-200 px-3 py-1.5 rounded-full shadow-sm flex items-center gap-1.5"><span class="text-slate-900 font-bold">{featuredProducts[0].rating}</span><span class="text-xs text-slate-500">/ 5</span></div>
          <div class="w-full flex flex-col justify-end h-full mt-12">
            <span class="text-xs uppercase tracking-widest text-slate-500 mb-2">{featuredProducts[0].category}</span>
            <h3 class="text-3xl text-slate-900 mb-2" style="font-family:'Noto Serif',serif;">{featuredProducts[0].brand}</h3>
            <p class="text-slate-900 font-semibold mb-3">{featuredProducts[0].name}</p>
            <!-- keyStat -->
            <div class="bg-slate-50 rounded-lg px-4 py-3 mb-4 flex items-center gap-3">
              <span class="text-2xl font-bold text-slate-900">{featuredProducts[0].keyStat.value}</span>
              <p class="text-xs text-slate-700 leading-tight">{featuredProducts[0].keyStat.label}</p>
            </div>
            <div class="flex items-center gap-2 mb-4">
              <span class="bg-emerald-100 text-slate-900 text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full">{featuredProducts[0].satisfaction}% satisfied</span>
            </div>
            <div class="flex items-center justify-between"><span class="text-2xl font-light text-slate-900">{featuredProducts[0].price}</span><span class="text-slate-900 font-bold border-b-2 border-[#b7ccb9] pb-1 text-sm">View program →</span></div>
          </div>
        </a>
      )}
      {featuredProducts[1] && (
        <a href={featuredProducts[1].affiliateUrl} target="_blank" rel="noopener sponsored" class="md:col-span-4 group relative overflow-hidden rounded-xl bg-slate-50 p-10 flex flex-col hover:shadow-xl transition-all border border-slate-200 min-h-[380px]">
          {featuredProducts[1].badge && <span class="absolute top-6 right-6 inline-block bg-emerald-600 text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full z-10 shadow-sm">★ {featuredProducts[1].badge}</span>}
          <div class="flex flex-col flex-grow mt-12">
            <span class="text-xs uppercase tracking-widest text-slate-500 mb-2">{featuredProducts[1].category}</span>
            <h3 class="text-3xl text-slate-900 mb-1" style="font-family:'Noto Serif',serif;">{featuredProducts[1].brand}</h3>
            <p class="font-semibold text-slate-700 mb-4">{featuredProducts[1].name}</p>
            <!-- keyStat -->
            <div class="bg-white rounded-lg px-4 py-3 mb-4 shadow-sm border border-slate-200">
              <span class="text-3xl font-bold text-emerald-600 block">{featuredProducts[1].keyStat.value}</span>
              <p class="text-[10px] text-slate-500 leading-tight mt-1">{featuredProducts[1].keyStat.label}</p>
            </div>
          </div>
          <div class="flex items-center justify-between mt-auto">
            <span class="text-2xl font-light text-slate-900">{featuredProducts[1].price}</span>
            <div class="flex items-center gap-2">
               <span class="text-[10px] text-slate-500">{featuredProducts[1].satisfaction}% satisfied</span>
               <span class="text-emerald-600 font-bold text-sm group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </div>
        </a>
      )}
      {featuredProducts[2] && (
        <a href={featuredProducts[2].affiliateUrl} target="_blank" rel="noopener sponsored" class="md:col-span-6 group relative overflow-hidden rounded-xl bg-white p-8 flex flex-col hover:shadow-xl transition-all min-h-[280px]">
          {featuredProducts[2].badge && <span class="inline-block mb-4 bg-emerald-100 text-slate-900 text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full w-fit">★ {featuredProducts[2].badge}</span>}
          <span class="text-xs uppercase tracking-widest text-slate-500 mb-2">{featuredProducts[2].category}</span>
          <h3 class="text-2xl text-slate-900 mb-2 pr-8" style="font-family:'Noto Serif',serif;">{featuredProducts[2].brand}</h3>
          <p class="text-slate-700 text-sm mb-3">{featuredProducts[2].tagline}</p>
          <!-- keyStat -->
          <div class="bg-slate-50 rounded-lg px-3 py-2 mb-3 flex items-center gap-2">
            <span class="text-xl font-bold text-slate-900">{featuredProducts[2].keyStat.value}</span>
            <p class="text-[10px] text-slate-700 leading-tight">{featuredProducts[2].keyStat.label}</p>
          </div>
          <div class="mt-auto flex items-center justify-between">
            <span class="text-xl font-light text-slate-900">{featuredProducts[2].price}</span>
            <div class="flex items-center gap-2">
              <span class="text-[10px] text-slate-500">{featuredProducts[2].satisfaction}% satisfied</span>
              <div class="flex items-center gap-1 bg-slate-50 border border-slate-200 px-3 py-1 rounded-full"><span class="text-slate-900 font-bold text-sm">{featuredProducts[2].rating}</span><span class="text-xs text-slate-500">★</span></div>
            </div>
          </div>
        </a>
      )}
      {featuredProducts[3] && (
        <a href={featuredProducts[3].affiliateUrl} target="_blank" rel="noopener sponsored" class="md:col-span-6 group relative overflow-hidden rounded-xl bg-slate-50 p-8 flex flex-col hover:shadow-xl transition-all min-h-[280px]">
          {featuredProducts[3].badge && <span class="inline-block mb-4 bg-emerald-600 text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full w-fit">★ {featuredProducts[3].badge}</span>}
          <span class="text-xs uppercase tracking-widest text-slate-500 mb-2">{featuredProducts[3].category}</span>
          <h3 class="text-2xl text-slate-900 mb-2" style="font-family:'Noto Serif',serif;">{featuredProducts[3].brand}</h3>
          <p class="text-slate-700 text-sm mb-3">{featuredProducts[3].tagline}</p>
          <!-- keyStat -->
          <div class="bg-white rounded-lg px-3 py-2 mb-3 flex items-center gap-2">
            <span class="text-xl font-bold text-slate-900">{featuredProducts[3].keyStat.value}</span>
            <p class="text-[10px] text-slate-700 leading-tight">{featuredProducts[3].keyStat.label}</p>
          </div>
          <div class="mt-auto flex items-center justify-between">
            <span class="text-xl font-light text-slate-900">{featuredProducts[3].price}</span>
            <div class="flex items-center gap-2">
              <span class="text-[10px] text-slate-500">{featuredProducts[3].satisfaction}% satisfied</span>
              <div class="flex items-center gap-1 bg-white border border-slate-200 px-3 py-1 rounded-full"><span class="text-slate-900 font-bold text-sm">{featuredProducts[3].rating}</span><span class="text-xs text-slate-500">★</span></div>
            </div>
          </div>
        </a>
      )}
    </div>
  </section>

  <!-- Latest Insights -->
  <section class="mb-32">
    <div class="flex justify-between items-end mb-10">
      <div>
        <span class="text-xs uppercase tracking-widest text-slate-500 mb-3 block font-semibold">Latest Insights</span>
        <h2 class="text-4xl text-slate-900" style="font-family:'Noto Serif',serif;">Clinical Comparisons</h2>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Article 1 -->
      <a href="/blog/ag1-vs-fs-greens" class="group relative overflow-hidden rounded-xl bg-slate-50 hover:shadow-xl transition-all border border-slate-200 flex flex-col">
        <div class="h-48 overflow-hidden">
          <img src="https://images.pexels.com/photos/1346347/pexels-photo-1346347.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Superfood Greens" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
        </div>
        <div class="p-8 flex flex-col flex-grow">
          <span class="inline-block mb-4 bg-white text-slate-900 text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full border border-slate-200 w-fit shadow-sm">Nutrition</span>
          <h3 class="text-2xl text-slate-900 mb-3 group-hover:text-emerald-600 transition-colors" style="font-family:'Noto Serif',serif;">AG1 versus FS Greens: Which Superfood Powder is Right for You in 2026</h3>
          <p class="text-slate-700 text-sm mb-6 leading-relaxed flex-grow">We compare AG1 by Athletic Greens and FS Greens. Read our objective breakdown of formulations, benefits, and costs to find the best green powder for your wellness routine.</p>
          <div class="flex items-center gap-3 mt-auto pt-4 border-t border-slate-200">
             <img class="w-8 h-8 rounded-full object-cover" src={expert.avatar} alt={expert.name}/>
             <span class="text-xs text-slate-500 font-semibold">Published by {expert.name}</span>
          </div>
        </div>
      </a>

      <!-- Article 2 -->
      <a href="/blog/mind-lab-pro-vs-hunter-focus" class="group relative overflow-hidden rounded-xl bg-slate-50 hover:shadow-xl transition-all border border-slate-200 flex flex-col">
        <div class="h-48 overflow-hidden">
          <img src="https://images.pexels.com/photos/3683074/pexels-photo-3683074.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Cognitive Nootropics" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
        </div>
        <div class="p-8 flex flex-col flex-grow">
          <span class="inline-block mb-4 bg-white text-slate-900 text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full border border-slate-200 w-fit shadow-sm">Mental Performance</span>
          <h3 class="text-2xl text-slate-900 mb-3 group-hover:text-emerald-600 transition-colors" style="font-family:'Noto Serif',serif;">Mind Lab Pro versus Hunter Focus: The Ultimate Brain Booster Showdown</h3>
          <p class="text-slate-700 text-sm mb-6 leading-relaxed flex-grow">A clinical comparison between Mind Lab Pro and Hunter Focus. We analyze the dosages and ingredient synergy to find the best nootropic for your cognitive demands.</p>
          <div class="flex items-center gap-3 mt-auto pt-4 border-t border-slate-200">
             <img class="w-8 h-8 rounded-full object-cover" src={expert.avatar} alt={expert.name}/>
             <span class="text-xs text-slate-500 font-semibold">Published by {expert.name}</span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- Quiz CTA -->
  <section class="py-32 px-8 text-center max-w-4xl mx-auto">
    <h2 class="text-4xl md:text-6xl text-slate-900 mb-8 italic" style="font-family:'Noto Serif',serif;">Which program is right for you?</h2>
    <p class="text-slate-700 text-lg mb-12">Our algorithm analyses your profile in 3 questions to recommend the program best suited to your goals.</p>
    <a href="/quiz"><button class="bg-emerald-600 text-white px-10 py-4 rounded-xl text-lg font-medium hover:bg-emerald-700 transition-all">Take the free quiz →</button></a>
    <p class="mt-6 text-xs text-slate-500 uppercase tracking-widest">3 questions · 2 minutes · Instant result</p>
  </section>

  <!-- E-E-A-T Expert Block -->
  <section class="bg-slate-50 py-16 px-8">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-10">
      <img class="w-24 h-24 rounded-full object-cover flex-shrink-0 shadow-lg" src={expert.avatar} alt={expert.name}/>
      <div>
        <span class="bg-emerald-600 text-white text-[10px] uppercase tracking-widest font-bold px-3 py-1 rounded-full">✓ Independently Verified</span>
        <p class="font-semibold text-slate-900 text-lg mt-3 mb-1" style="font-family:'Noto Serif',serif;">{expert.name}</p>
        <p class="text-xs text-slate-500 uppercase tracking-wide mb-3">{expert.title}</p>
        <p class="text-sm text-slate-700 leading-relaxed mb-3">{expert.bio}</p>
        <p class="text-xs text-slate-500 italic border-l-2 border-slate-300 pl-3">{expert.disclosure}</p>
      </div>
    </div>
  </section>
</main>
</MainLayout>
