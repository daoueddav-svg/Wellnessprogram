---
import MainLayout from '../layouts/MainLayout.astro';
import AffiliateButton from '../components/AffiliateButton.astro';
import { products, expert } from '../data/products';

const top3 = [...products].sort((a, b) => b.expertScore - a.expertScore).slice(0, 3);
const allSorted = [...products].sort((a, b) => b.expertScore - a.expertScore);
---
<MainLayout title="Wellness Program Comparison 2024 | Wellness Sanctuary" description="Expert comparison table of the best wellness programs: Noom, Ritual, Alo Moves, WHOOP, Headspace. Medical criteria, pricing, honest pros & cons.">
<main class="max-w-screen-2xl mx-auto px-8 py-16">

  <!-- Hero -->
  <header class="mb-20 text-center md:text-left max-w-3xl">
    <span class="text-xs uppercase tracking-widest text-slate-900 mb-4 block font-semibold">Comparative Analysis · Updated April 2024</span>
    <h1 class="text-5xl md:text-6xl text-slate-900 leading-tight mb-6" style="font-family:'Noto Serif',serif;">Data-Driven Excellence,<br/><span class="italic">Put in Perspective.</span></h1>
    <p class="text-lg text-slate-700 leading-relaxed">A rigorous evaluation based on 12 core criteria. Each program is tested and validated by our independent editorial panel.</p>
    <div class="flex items-center gap-3 mt-6">
      <img class="w-10 h-10 rounded-full object-cover" src={expert.avatar} alt={expert.name}/>
      <div>
        <p class="text-xs font-semibold text-slate-900">{expert.name}</p>
        <p class="text-[10px] text-slate-500 uppercase tracking-wide">{expert.title}</p>
      </div>
      <span class="ml-2 bg-emerald-100 text-slate-900 text-[10px] uppercase tracking-wider font-bold px-2 py-0.5 rounded-full">✓ Verified</span>
    </div>
  </header>

  <!-- Comparison Table Top 3 -->
  <section class="mb-32 overflow-x-auto no-scrollbar">
    <div class="min-w-[900px]">
      <!-- Sticky header -->
      <div class="sticky top-[73px] z-40 bg-slate-50 grid rounded-t-xl overflow-hidden" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
        <div class="px-6 py-6"><h3 class="text-lg text-slate-900 font-semibold" style="font-family:'Noto Serif',serif;">Criteria</h3></div>
        {top3.map(p => (
          <div class="px-6 py-6 text-center border-l border-slate-200">
            <span class="text-[10px] uppercase tracking-widest text-slate-500 block mb-1">{p.category}</span>
            <div class="font-semibold text-slate-900 italic" style="font-family:'Noto Serif',serif;">{p.brand}</div>
            <div class="text-xs text-slate-500">{p.name}</div>
            {p.badge && <span class="inline-block mt-2 bg-emerald-600 text-white text-[9px] uppercase tracking-wider font-bold px-2 py-0.5 rounded-full">★ {p.badge}</span>}
          </div>
        ))}
      </div>
      <!-- Table body -->
      <div class="bg-white shadow-sm rounded-b-xl overflow-hidden">
        <!-- Expert Score -->
        <div class="grid border-b border-slate-200" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
          <div class="px-6 py-8 flex items-center"><span class="text-xs uppercase tracking-widest text-slate-500 font-semibold">Expert Score</span></div>
          {top3.map(p => (
            <div class="px-6 py-8 text-center border-l border-slate-200 flex flex-col items-center justify-center gap-1">
              <div class="text-2xl font-bold text-slate-900">{p.expertScore}<span class="text-sm font-light text-slate-500">/10</span></div>
              <div class="w-20 h-1 bg-[#e8e8e6] rounded-full overflow-hidden mt-1"><div class="h-full bg-emerald-600 rounded-full" style={`width:${p.expertScore*10}%`}></div></div>
            </div>
          ))}
        </div>
        <!-- User Rating -->
        <div class="grid border-b border-slate-200 bg-slate-50/50" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
          <div class="px-6 py-8 flex items-center"><span class="text-xs uppercase tracking-widest text-slate-500 font-semibold">User Rating</span></div>
          {top3.map(p => (
            <div class="px-6 py-8 text-center border-l border-slate-200"><span class="font-bold text-xl text-slate-900">{p.rating}</span><span class="text-sm text-slate-500"> ★ / 5</span></div>
          ))}
        </div>
        <!-- Price -->
        <div class="grid border-b border-slate-200" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
          <div class="px-6 py-8 flex items-center"><span class="text-xs uppercase tracking-widest text-slate-500 font-semibold">Monthly Cost</span></div>
          {top3.map(p => (
            <div class="px-6 py-8 text-center border-l border-slate-200"><span class="text-2xl font-light text-slate-900">{p.price}</span></div>
          ))}
        </div>
        <!-- Telehealth -->
        <div class="grid border-b border-slate-200 bg-slate-50/50" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
          <div class="px-6 py-8 flex items-center"><span class="text-xs uppercase tracking-widest text-slate-500 font-semibold">Telehealth Access</span></div>
          {top3.map(p => (
            <div class="px-6 py-8 text-center border-l border-slate-200">
              {p.features.telehealth ? <span class="material-symbols-outlined text-slate-900" style="font-variation-settings:'FILL' 1">check_circle</span> : <span class="material-symbols-outlined text-slate-300">remove_circle</span>}
            </div>
          ))}
        </div>
        <!-- Personal Coach -->
        <div class="grid border-b border-slate-200" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
          <div class="px-6 py-8 flex items-center"><span class="text-xs uppercase tracking-widest text-slate-500 font-semibold">Personal Coach</span></div>
          {top3.map(p => (
            <div class="px-6 py-8 text-center border-l border-slate-200">
              {p.features.personalCoach ? <span class="material-symbols-outlined text-slate-900" style="font-variation-settings:'FILL' 1">check_circle</span> : <span class="material-symbols-outlined text-slate-300">remove_circle</span>}
            </div>
          ))}
        </div>
        <!-- Clinically Certified -->
        <div class="grid border-b border-slate-200 bg-slate-50/50" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
          <div class="px-6 py-8 flex items-center"><span class="text-xs uppercase tracking-widest text-slate-500 font-semibold">Clinically Certified</span></div>
          {top3.map(p => (
            <div class="px-6 py-8 text-center border-l border-slate-200">
              {p.features.certified ? <span class="material-symbols-outlined text-slate-900" style="font-variation-settings:'FILL' 1">check_circle</span> : <span class="material-symbols-outlined text-slate-300">remove_circle</span>}
            </div>
          ))}
        </div>
        <!-- Vegan -->
        <div class="grid border-b border-slate-200" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
          <div class="px-6 py-8 flex items-center"><span class="text-xs uppercase tracking-widest text-slate-500 font-semibold">Vegan / Ethical</span></div>
          {top3.map(p => (
            <div class="px-6 py-8 text-center border-l border-slate-200">
              {p.features.vegan ? <span class="material-symbols-outlined text-slate-900" style="font-variation-settings:'FILL' 1">check_circle</span> : <span class="material-symbols-outlined text-slate-300">remove_circle</span>}
            </div>
          ))}
        </div>
        <!-- CTA -->
        <div class="grid" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
          <div class="px-6 py-10"></div>
          {top3.map(p => (
            <div class="px-6 py-10 flex justify-center border-l border-slate-200">
              <AffiliateButton id={p.id} text="View Program" outline={true} />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- All Programs List -->
  <section class="mb-32">
    <h2 class="text-4xl text-slate-900 mb-12" style="font-family:'Noto Serif',serif;">All Programs Reviewed</h2>
    <div class="space-y-6">
      {allSorted.map((p, i) => (
        <div class="bg-white rounded-xl p-8 shadow-sm hover:shadow-lg transition-all grid grid-cols-1 md:grid-cols-12 gap-6 items-center">
          <div class="md:col-span-1"><span class="text-2xl font-light text-slate-300">#{i+1}</span></div>
          <div class="md:col-span-2"><img class="w-16 h-16 rounded-lg object-cover" src={p.image} alt={p.name}/></div>
          <div class="md:col-span-4">
            <span class="text-[10px] uppercase tracking-widest text-slate-500">{p.category}</span>
            <h3 class="text-xl text-slate-900 font-semibold mt-1" style="font-family:'Noto Serif',serif;">{p.brand}</h3>
            <p class="text-sm text-slate-700 mt-1">{p.tagline}</p>
          </div>
          <div class="md:col-span-2 text-center">
            <div class="text-2xl font-bold text-slate-900">{p.expertScore}<span class="text-sm font-light text-slate-500">/10</span></div>
            <div class="text-xs text-slate-500 uppercase tracking-wide mt-1">Expert score</div>
          </div>
          <div class="md:col-span-3 flex flex-col items-end gap-3">
            <span class="text-xl font-light text-slate-900">{p.price}</span>
            <AffiliateButton id={p.id} text="View →" />
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- E-E-A-T -->
  <section class="bg-slate-50 rounded-2xl p-12 mb-16">
    <div class="flex flex-col md:flex-row items-start gap-10">
      <img class="w-20 h-20 rounded-full object-cover flex-shrink-0" src={expert.avatar} alt={expert.name}/>
      <div>
        <span class="bg-emerald-600 text-white text-[10px] uppercase tracking-widest font-bold px-3 py-1 rounded-full">✓ Independently Verified</span>
        <p class="font-semibold text-slate-900 text-xl mt-4 mb-1" style="font-family:'Noto Serif',serif;">{expert.name}</p>
        <p class="text-xs text-slate-500 uppercase tracking-wide mb-4">{expert.credentials}</p>
        <p class="text-sm text-slate-700 leading-relaxed mb-4">{expert.bio}</p>
        <p class="text-xs text-slate-500 italic border-l-2 border-slate-300 pl-3">{expert.disclosure}</p>
      </div>
    </div>
  </section>

</main>
</MainLayout>
