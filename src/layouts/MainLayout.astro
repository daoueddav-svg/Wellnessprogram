---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Wellness Sanctuary | Expert Wellness Program Reviews',
  description = 'Independent medical reviews of the best wellness programs. Honest pros & cons, expert scores, and personalised recommendations.',
} = Astro.props;

const updatedDate = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Impact.com site verification -->
  <meta name="impact-site-verification" value="455d2449-9684-416c-a93a-7490ddba7781" />
</head>

<body>

  <!-- ─── HEADER / NAV ─── -->
  <nav class="sticky top-0 w-full z-50 bg-stone-50/80 backdrop-blur-xl shadow-sm">
    <div class="flex justify-between items-center w-full px-8 py-4 max-w-screen-2xl mx-auto">

      <a href="/" class="font-serif italic text-2xl text-[#334537]">Wellness Sanctuary</a>

      <div class="hidden md:flex gap-8 items-center">
        <a href="/" class="text-[#334537] font-semibold border-b-2 border-[#334537] pb-1 text-sm tracking-wide">Programs</a>
        <a href="/comparison" class="text-stone-500 hover:text-[#334537] transition-colors text-sm tracking-wide">Compare</a>
        <a href="/comparison" class="text-stone-500 hover:text-[#334537] transition-colors text-sm tracking-wide">Expert Reviews</a>
        <a href="/quiz" class="text-stone-500 hover:text-[#334537] transition-colors text-sm tracking-wide">Find My Program</a>
      </div>

      <div class="flex items-center gap-6">
        <a href="/quiz">
          <button class="bg-[#334537] text-white px-6 py-2.5 rounded-md text-sm font-medium hover:opacity-90 active:scale-[0.99] transition-all">
            Get Consulted
          </button>
        </a>
        <div class="w-10 h-10 rounded-full overflow-hidden bg-[#eeeeec]">
          <img
            alt="User profile"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDCCBiW-62CmZ8fJevQa_MgC9tXqOOJW_A-r_lONY4NUF_0KoRurqBop-8t7qmBhW2c_Cyo981ZwuutOsh8oaleBfOC0oWLvK9JPIpWAu2s4KIZka-wgNJ7wGvcCsS_j7q_kjb1zvgMA9Jp-XWsI2JZj9wMyDhajJZdQUcAC5k5-Hx_VHov3UuVz_gpPMomSgRZxS9qIeG48TtUU8JTALEj99q88hOwdv8CBHS45VQEjkrkxrlz4-QUCbO_krAMXOBBix5gY6NjK1w"
          />
        </div>
      </div>

    </div>
    <div class="bg-stone-100/50 h-[1px] w-full"></div>
  </nav>

  <!-- ─── PAGE CONTENT ─── -->
  <slot />

  <!-- ─── FOOTER ─── -->
  <footer class="bg-stone-100 py-12 px-8 w-full mt-16">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6 max-w-screen-2xl mx-auto">
      <div class="font-serif text-lg text-[#334537]">Wellness Sanctuary</div>
      <div class="flex flex-wrap justify-center gap-8">
        <a class="text-xs uppercase tracking-widest text-stone-500 hover:text-[#4A5D4E] transition-colors" href="#">Privacy Policy</a>
        <a class="text-xs uppercase tracking-widest text-stone-500 hover:text-[#4A5D4E] transition-colors" href="#">Terms of Service</a>
        <a class="text-xs uppercase tracking-widest text-stone-500 hover:text-[#4A5D4E] transition-colors" href="#">Expert Board</a>
        <a class="text-xs uppercase tracking-widest text-stone-500 hover:text-[#4A5D4E] transition-colors" href="#">Contact Us</a>
      </div>
    </div>
    <div class="pt-12 mt-12 bg-stone-200 text-center px-6">
      <div class="max-w-4xl mx-auto text-left mb-8 pb-8 border-b border-stone-300">
        <p class="text-xs text-stone-500 leading-relaxed mb-3"><strong>Medical Disclaimer:</strong> The content provided on Wellness Sanctuary is for informational purposes only and is not intended as a substitute for professional medical advice, diagnosis, or treatment. Always seek the advice of your physician or other qualified health provider with any questions you may have regarding a medical condition.</p>
        <p class="text-xs text-stone-500 leading-relaxed"><strong>Affiliate Disclosure:</strong> Some of the links on this website are affiliate links (redirected via /go/). This means that if you click on the link and purchase the item, we will receive an affiliate commission at no extra cost to you. We only recommend products or services that have been medically vetted.</p>
      </div>
      <p class="text-xs uppercase tracking-widest text-stone-800 pb-12">
        © {new Date().getFullYear()} Wellness Sanctuary. All rights reserved. Last updated: {updatedDate}.
      </p>
    </div>
  </footer>

</body>
</html>
